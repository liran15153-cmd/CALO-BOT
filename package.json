{
  "name": "calo-bot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:all": "npm install && npm --prefix frontend install && python -m pip install -r backend/requirements.txt",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "python -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "test": "node scripts/test.mjs",
    "test:backend": "python -m pytest backend/tests",
    "test:memory-eval": "python -m backend.tests.eval.run_memory_gold_set",
    "test:frontend": "npm --prefix frontend test -- --run",
    "scan:secrets": "python scripts/secret_scan.py",
    "verify:supabase": "python scripts/verify_supabase_live.py",
    "lint": "python -m compileall backend/app && npm --prefix frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
