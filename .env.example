APP_ENV=development
DATABASE_URL=sqlite:///./data/app.db
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Supabase. Use placeholders here only; put real values in .env.local.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_AUTH_REQUIRED=false
SUPABASE_STORAGE_BUCKET=meal-images

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Optional override. Leave empty to use ANTHROPIC_MODEL for chat.
ANTHROPIC_CHAT_MODEL=
DAILY_AI_TOKEN_LIMIT=50000
# Keep the Hebrew quality guard active in normal development. Use "off" only for raw provider QA.
LANGUAGE_GUARD_ENABLED=true
LANGUAGE_GUARD_MODE=repair

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
